{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "functions": {
        "api/chat.js": {
            "maxDuration": 60
        },
        "api/telegram.js": {
            "maxDuration": 60
        },
        "api/analyze.js": {
            "maxDuration": 30
        },
        "api/events.js": {
            "maxDuration": 30
        },
        "api/calendar.js": {
            "maxDuration": 30
        },
        "api/metrics.js": {
            "maxDuration": 30
        },
        "api/cron-recordatorios.js": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron-recordatorios",
            "schedule": "0 13 * * *"
        }
    ]
}
